{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@forgelet/shared-types": ["packages/shared-types/src/index.ts"],
      "@forgelet/sdk-core": ["packages/sdk-core/src/index.ts"],
      "@forgelet/sdk-runtime": ["packages/sdk-runtime/src/index.ts"],
      "@forgelet/storage-core": ["packages/storage-core/src/index.ts"],
      "@forgelet/harness": ["packages/harness/src/index.ts"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "types": ["node"],
    "outDir": "dist"
  }
}
