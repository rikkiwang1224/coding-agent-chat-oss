# Optional fallback values. The desktop Settings screen takes priority.
AGENT_LLM_PROVIDER=anthropic
AGENT_LLM_MODEL=claude-sonnet-4-5-20250929
# AGENT_LLM_API_TOKEN=<your_token>
# AGENT_LLM_BASE_URL=https://api.anthropic.com

# Agent runtime options
# AGENT_MAX_TURNS=24
# AGENT_ALLOWED_TOOLS=Bash,Read,Grep,Glob,LS,Edit,MultiEdit,Write
# AGENT_DISALLOWED_TOOLS=
# CLAUDE_PERMISSION_MODE=default
# CLAUDE_CODE_SETTING_SOURCES=project

# Set to 1 if you explicitly want Claude Code attribution trailers in commits.
# LATTICE_CODE_CLAUDE_ATTRIBUTION=1

# Tencent Cloud CVM — eval ECS start/stop (packages/harness/eval/start-ecs.sh)
# Create API keys: console.cloud.tencent.com/cam/capi
# TENCENTCLOUD_SECRET_ID=
# TENCENTCLOUD_SECRET_KEY=
# TENCENT_ECS_REGION=ap-guangzhou
# TENCENT_ECS_INSTANCE_ID=ins-xxxxxxxx
# ECS_IP=119.91.220.67
