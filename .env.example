# DeepSeek-first defaults for local development.
# Copy to `.env` at the repo root — CLI and eval scripts load it automatically
# (does not override variables already set in your shell).
# Desktop chat uses Settings first; `.env` is a fallback for dev.

# Required for CLI / eval (desktop can also set the key in Settings)
DEEPSEEK_API_KEY=sk-your-key-here

# Optional overrides (DeepSeek is the default provider everywhere)
# LATTICE_CODE_PROVIDER=deepseek
# LATTICE_CODE_MODEL=deepseek-v4-pro
# LATTICE_CODE_BASE_URL=https://api.deepseek.com
# LATTICE_CODE_API_KEY=sk-your-key-here

# DeepSeek thinking mode: off | high | max (SWE-bench eval defaults to max)
# THINKING_MODE=off

# Runtime layout
# LATTICE_CODE_HOME=~/.lattice-code
# LATTICE_CODE_ENV_FILE=/path/to/.env

# Agent loop (optional)
# LATTICE_CODE_MAX_TURNS=100
# LATTICE_CODE_TEMPERATURE=0.7

# Set to 1 if you explicitly want Claude Code attribution trailers in commits.
# LATTICE_CODE_CLAUDE_ATTRIBUTION=1

# Tencent Cloud CVM — eval ECS start/stop (packages/harness/eval/start-ecs.sh)
# Create API keys: console.cloud.tencent.com/cam/capi
# TENCENTCLOUD_SECRET_ID=
# TENCENTCLOUD_SECRET_KEY=
# TENCENT_ECS_REGION=ap-guangzhou
# TENCENT_ECS_INSTANCE_ID=ins-xxxxxxxx
# ECS_IP=119.91.220.67
