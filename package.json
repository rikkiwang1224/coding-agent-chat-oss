{
  "name": "forgelet",
  "version": "0.1.0",
  "description": "Open-source coding agent — desktop chat and terminal CLI powered by the Forgelet harness.",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.10.2",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @forgelet/chat-desktop dev",
    "dev:cli": "pnpm --filter @forgelet/cli dev",
    "start": "pnpm --filter @forgelet/chat-desktop start",
    "forgelet": "pnpm --filter @forgelet/cli dev",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "eval": "pnpm --filter @forgelet/harness eval",
    "eval:swe": "pnpm --filter @forgelet/harness eval:swe",
    "eval:swe:verify": "pnpm --filter @forgelet/harness eval:swe:verify",
    "eval:swe:setup": "pnpm --filter @forgelet/harness eval:swe:setup"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
