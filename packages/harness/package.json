{
  "name": "@forgelet/harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx eval/run.ts",
    "eval:swe": "tsx eval/swe-bench/run.ts",
    "eval:swe:verify": "tsx eval/swe-bench/verify.ts",
    "eval:swe:setup": "cd eval/swe-bench && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt",
    "eval:swe:traces": "tsx eval/swe-bench/summarize-traces.ts",
    "eval:swe:analyze": "bash eval/swe-bench/analyze-run.sh",
    "eval:swe:merge-report": "python3 eval/swe-bench/merge-eval-report.py",
    "eval:swe:guard-smoke": "tsx eval/swe-bench/guard-smoke.ts",
    "eval:ecs:start": "bash eval/start-ecs.sh --wait",
    "eval:ecs:stop": "bash eval/stop-ecs.sh --wait",
    "eval:tb:bundle": "bash eval/terminal-bench/bundle-harbor-for-ecs.sh",
    "eval:tb:setup": "bash eval/terminal-bench/setup.sh",
    "eval:tb:prepare": "bash eval/terminal-bench/prepare-forgelet.sh",
    "eval:tb:sync": "bash eval/terminal-bench/sync-to-ecs.sh",
    "eval:tb:pull": "bash eval/terminal-bench/pull-and-report.sh",
    "eval:tb:smoke": "bash eval/terminal-bench/smoke.sh",
    "eval:tb": "bash eval/terminal-bench/tb-docker-batch.sh",
    "install:codebase-memory": "bash scripts/install-codebase-memory.sh",
    "fetch:codebase-memory-source": "bash eval/swe-bench/fetch-codebase-memory-source.sh",
    "build:codebase-memory-swe": "bash eval/swe-bench/build-codebase-memory-swe.sh",
    "build:codebase-memory-swe-on-ecs": "bash eval/swe-bench/build-codebase-memory-swe-on-ecs.sh",
    "sync:codebase-memory-swe": "bash eval/swe-bench/sync-codebase-memory-swe-to-ecs.sh",
    "eval:swe:lite86:sync": "bash eval/swe-bench/lite-86-sync-to-ecs.sh",
    "eval:swe:lite86:start": "bash eval/swe-bench/lite-86-start.sh",
    "eval:swe:lite86:monitor": "bash eval/swe-bench/lite-86-monitor.sh watch"
  },
  "dependencies": {
    "@forgelet/sdk-core": "workspace:*",
    "@forgelet/sdk-runtime": "workspace:*",
    "@forgelet/shared-types": "workspace:*",
    "@forgelet/storage-core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
