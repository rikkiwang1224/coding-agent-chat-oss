{
  "name": "@forgelet/harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "eval": "tsx eval/run.ts",
    "eval:swe": "tsx eval/swe-bench/run.ts",
    "eval:swe:verify": "tsx eval/swe-bench/verify.ts",
    "eval:swe:setup": "cd eval/swe-bench && python3 -m venv .venv && .venv/bin/pip install -r requirements.txt"
  },
  "dependencies": {
    "@forgelet/sdk-core": "workspace:*",
    "@forgelet/shared-types": "workspace:*",
    "@forgelet/storage-core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
